    {
      "locale": "frFR",
      "text": "« Les Drukharis sont venus dans ce monde ? Pourquoi ? »",
      "modification_date": "2024-02-26T17:18:59.2548897Z",
      "translated_from": "enGB",
      "translation_date": "2024-02-26T17:19:31.1945940Z",
