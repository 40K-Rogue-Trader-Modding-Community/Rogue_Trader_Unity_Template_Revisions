          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“审判庭的渣滓活该落得这种下场。”",
      "modification_date": "2024-02-26T17:32:33.7016492Z",
      "translated_from": "enGB",
      "translation_date": "2024-03-25T13:52:22.1389416Z",
      "original_text": "\"It is what you Inquisitorial rats deserve.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-09-20T12:03:39.6890809Z",
          "locale_text": "“这就是你们这些帝国的臭鱼烂虾应得的下场。”",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「これこそ、お前たち異端審問官にふさわしい末路だ」",
