      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-09-20T12:03:39.4701846Z",
          "locale_text": "“崩坏的迹象正在显现，通过现实世界展现出来。”",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「崩壊の兆しが、現実の中に浸透しつつある」",
