      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-09-12T08:36:00.7296235Z",
          "locale_text": "«Las señales del colapso emergen, haciéndose patentes en la realidad».",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“崩坏的迹象正在显现，通过真实世界蔓延开来。”",
