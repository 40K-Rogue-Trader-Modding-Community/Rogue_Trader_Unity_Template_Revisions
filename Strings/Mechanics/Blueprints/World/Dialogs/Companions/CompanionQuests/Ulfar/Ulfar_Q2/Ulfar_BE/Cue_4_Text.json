      "translated_from": "enGB",
      "translation_date": "2023-08-24T09:36:21.3457667Z",
      "original_text": "\"Having spoken thus,\nupon the snow the Aett-Vater fell.",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-08-24T09:36:21.3457686Z",
