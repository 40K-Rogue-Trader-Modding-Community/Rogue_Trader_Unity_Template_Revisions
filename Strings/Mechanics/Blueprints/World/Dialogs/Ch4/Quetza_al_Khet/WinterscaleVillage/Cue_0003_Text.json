      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-17T19:38:55.6191712Z",
          "locale_text": "« Quoi, vous n'avez plus de questions ? »",
          "speaker": "Quetza-al_Winterscale",
          "speaker_gender": "Male"
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「もう質問はないのか？」",
