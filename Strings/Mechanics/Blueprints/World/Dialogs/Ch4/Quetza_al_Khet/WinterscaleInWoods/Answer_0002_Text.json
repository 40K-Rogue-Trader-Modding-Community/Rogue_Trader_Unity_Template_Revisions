    {
      "locale": "esES",
      "text": "«Este reencuentro con viejas amistades deja mucho que desear».",
      "modification_date": "2024-02-26T17:29:02.9053836Z",
      "translated_from": "enGB",
      "translation_date": "2024-02-26T17:29:02.9053837Z",
      "original_text": "\"So much for a reunion of old friends.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-09-16T14:43:38.7988837Z",
          "locale_text": "«Henos aquí, dos viejos amigos reunidos por fin».",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“你的老朋友来找你了。”",
      "modification_date": "2024-02-26T17:32:33.4609313Z",
      "translated_from": "enGB",
      "translation_date": "2024-03-25T13:52:20.0178997Z",
      "original_text": "\"So much for a reunion of old friends.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-09-24T09:37:14.5499134Z",
          "locale_text": "“你的老朋友来和你见面了。”",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« C'est raté pour les retrouvailles entre vieux amis. »",
      "modification_date": "2024-02-26T15:57:38.9123297Z",
      "translated_from": "enGB",
      "translation_date": "2024-02-26T17:19:30.9733356Z",
      "original_text": "\"So much for a reunion of old friends.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-17T19:38:54.6615699Z",
          "locale_text": "« Vous devriez vous réjouir de ces retrouvailles entre vieux amis. »",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「旧友との再会だというのに」",
      "modification_date": "2024-02-16T12:24:14.9529443Z",
