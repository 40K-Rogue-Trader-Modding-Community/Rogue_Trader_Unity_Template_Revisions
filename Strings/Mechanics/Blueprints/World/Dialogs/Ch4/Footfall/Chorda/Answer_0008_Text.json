          "trait_date": "2023-10-17T12:07:44.4643383+03:00",
          "locale_text": "\"Ich habe genug erfahren. Eure Fehde hat nichts mit mir zu tun.\"",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
