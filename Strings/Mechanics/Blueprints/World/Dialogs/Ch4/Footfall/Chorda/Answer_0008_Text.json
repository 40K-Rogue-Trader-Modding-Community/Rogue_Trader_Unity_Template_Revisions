      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-09T15:55:34.1211327+03:00",
          "locale_text": "«Ya he escuchado suficiente. Sus peleas no son de mi incumbencia».",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Ich habe genug gehört. Eure Fehde hat nichts mit mir zu tun.\"",
