          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Con eso, podemos concluir el juicio».",
      "modification_date": "2024-04-22T19:28:48.6127181+03:00",
      "translated_from": "enGB",
      "translation_date": "2024-04-22T19:28:48.6127187+03:00",
      "original_text": "\"On that, we can conclude the trial.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-09T15:55:34.3928343+03:00",
          "locale_text": "«El juicio puede terminar».",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Damit können wir die Verhandlung schließen.\"",
      "modification_date": "2024-04-22T14:09:55.0572888+03:00",
      "translated_from": "enGB",
      "translation_date": "2024-04-22T14:09:55.0572901+03:00",
      "original_text": "\"On that, we can conclude the trial.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-17T12:07:47.8125765+03:00",
          "locale_text": "\"Der Prozess kann nun enden.\"",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Sur ce, il me semble que le procès est clos. »",
