          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「これにて裁判は終わりだ」",
      "modification_date": "2024-04-22T19:28:48.1021254+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-03-17T09:15:04.4000088+03:00",
      "original_text": "\"On that, we can conclude the trial.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-03-17T09:15:04.4000093+03:00",
