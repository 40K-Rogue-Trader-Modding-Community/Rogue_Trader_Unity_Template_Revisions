          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Discutir con usted no tiene sentido. Que pase lo que tenga que pasar».",
      "modification_date": "2024-04-25T19:46:28.8168844+03:00",
      "translated_from": "enGB",
      "translation_date": "2024-04-25T19:46:28.8168847+03:00",
      "original_text": "\"Arguing with you is pointless. What will be will be.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-09T15:55:34.252804+03:00",
          "locale_text": "«Discutir con usted no tiene sentido. Pase lo que pase».",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Mit Euch zu diskutieren, ist sinnlos. Es kommt, was kommt.\"",
      "modification_date": "2024-05-15T16:49:19.6170795+03:00",
      "translated_from": "enGB",
      "translation_date": "2024-05-15T16:49:19.6170797+03:00",
      "original_text": "\"Arguing with you is pointless. What will be will be.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-17T12:07:46.0049873+03:00",
          "locale_text": "\"Mit Euch zu diskutieren, ist sinnlos. Komme, was wolle.\"",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Je vois que discuter avec vous ne mène à rien. Advienne que pourra. »",
      "modification_date": "2024-05-07T08:58:21.1108825+03:00",
      "translated_from": "enGB",
      "translation_date": "2024-05-07T08:58:21.1108827+03:00",
      "original_text": "\"Arguing with you is pointless. What will be will be.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-25T12:08:51.3961902+03:00",
          "locale_text": "« Je vois que discuter avec vous ne mène à rien. Adviendra ce qui adviendra. »",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
