      "translated_from": "enGB",
      "translation_date": "2024-04-25T19:46:28.978808+03:00",
      "original_text": "\"Thank you for your tact, young von Valancius.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2023-10-09T15:55:34.2746348+03:00",
          "locale_text": "«Gracias por su tacto, hij{mf|o|a} mí{mf|o|a}».",
