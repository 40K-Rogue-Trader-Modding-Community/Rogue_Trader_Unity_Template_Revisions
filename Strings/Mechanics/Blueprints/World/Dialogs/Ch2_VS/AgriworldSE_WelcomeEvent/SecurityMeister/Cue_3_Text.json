      "translation_date": "2026-06-07T13:58:26.1371346Z",
      "original_text": "\"A remarkably well-timed question and, as such, a rhetorical one.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-07T13:58:26.1371355Z",
          "locale_text": "« Une question remarquablement opportune et, donc, de pure forme. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Tam zamanında sorulmuş, dolayısıyla retorik bir soru.\"",
      "modification_date": "2026-06-08T14:24:54.5419666Z",
