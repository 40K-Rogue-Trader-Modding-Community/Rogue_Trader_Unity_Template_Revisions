    {
      "locale": "esES",
      "text": "«En ese caso, moriremos en familia».",
      "modification_date": "2024-06-24T19:23:56.3851703Z",
      "translated_from": "enGB",
      "translation_date": "2024-06-24T19:23:56.3851705Z",
      "original_text": "\"In that case, we will die together as a family.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2024-06-24T19:23:56.3851718Z",
          "locale_text": "«En ese caso, moriremos en familia».",
