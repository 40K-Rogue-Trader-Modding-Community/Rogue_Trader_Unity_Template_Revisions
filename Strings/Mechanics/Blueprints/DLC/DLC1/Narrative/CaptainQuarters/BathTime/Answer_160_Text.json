        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Vous avez raison, cette boisson a l'air peu conventionnelle. »",
      "modification_date": "2026-06-02T08:53:12.9965695Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-02T08:53:12.9965697Z",
      "original_text": "\"You're right, it sounds like a rare brew.\"",
      "traits": [
