    },
    {
      "locale": "zhCN",
      "text": "“你说得没错，听起来确实像是稀有佳酿。”",
      "modification_date": "2026-06-01T08:49:02.8397188Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-01T08:49:02.8397190Z",
