    {
      "locale": "ruRU",
      "text": "\"Вы увидели Янус после нескольких веков. Каково это?\"",
      "modification_date": "2026-04-08T14:04:50.7337203Z"
    },
    {
      "locale": "enGB",
      "text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "modification_date": "2026-04-17T13:07:44.9042094Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-23T12:26:54.5075208Z",
      "original_text": "\"Вы увидели Янус после нескольких веков. Каково это?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-17T13:07:44.9042118Z",
          "locale_text": "\"You saw Janus again after several centuries. How did it feel?\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-23T12:26:54.5075216Z",
          "locale_text": "\"You saw Janus again after several centuries. How did it feel?\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-03-03T08:07:32.0918472Z",
          "locale_text": "\"How did you feel, seeing Janus again?\""
        },
        {
          "trait": "TK_tr",
          "trait_date": "2026-04-17T13:07:44.9042125Z",
          "locale_text": "\"You saw Janus again after several centuries. How did it feel?\""
        },
        {
          "trait": "AD_ed",
          "trait_date": "2026-04-23T12:26:54.5075219Z",
          "locale_text": "\"You saw Janus again after several centuries. How did it feel?\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「ジャヌスをまた見た時、どう感じたか？」",
      "modification_date": "2026-03-05T13:23:14.7357643Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-04T08:53:17.2682300Z",
      "original_text": "\"How did you feel, seeing Janus again?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-03-04T08:53:17.2682307Z",
          "locale_text": "「ジャヌスをまた見た時、どう感じましたか？」"
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“几个世纪后再次看到加努斯，你有什么感觉？”",
      "modification_date": "2026-05-05T09:59:59.2971770Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-05T09:59:59.2971771Z",
      "original_text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-05T09:59:59.2971783Z",
          "locale_text": "“几个世纪后再次看到加努斯，你有什么感觉？”"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Ha vuelto a Janus tras varios siglos. ¿Qué se siente?».",
      "modification_date": "2026-05-05T09:57:19.1922856Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-05T09:57:19.1922857Z",
      "original_text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-05T09:57:19.1922863Z",
          "locale_text": "«Ha vuelto a Janus tras varios siglos. ¿Qué se siente?»."
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Ihr habt Janus nach mehreren Jahrhunderten wiedergesehen. Wie hat sich das angefühlt?\"",
      "modification_date": "2026-05-06T08:00:37.2285399Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:00:37.2285400Z",
      "original_text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:00:37.2285408Z",
          "locale_text": "\"Ihr habt Janus nach mehreren Jahrhunderten wiedergesehen. Wie hat sich das angefühlt?\""
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Vous avez fini par revoir Janus après plusieurs siècles. Qu'avez-vous ressenti ? »",
      "modification_date": "2026-05-06T08:02:27.3672892Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:02:27.3672894Z",
      "original_text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:02:27.3672908Z",
          "locale_text": "« Vous avez fini par revoir Janus après plusieurs siècles. Qu'avez-vous ressenti ? »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Yüzyıllar sonra Janus'u tekrar gördün. Nasıl hissettin?\"",
      "modification_date": "2026-05-06T08:04:42.9884963Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:04:42.9884965Z",
      "original_text": "\"You saw Janus again after several centuries. How did it feel?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:04:42.9884973Z",
          "locale_text": "\"Yüzyıllar sonra Janus'u tekrar gördün. Nasıl hissettin?\""
