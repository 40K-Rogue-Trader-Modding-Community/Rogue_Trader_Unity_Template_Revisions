    {
      "locale": "ruRU",
      "text": "\"Не произноси слов, о которых придется пожалеть\".",
      "modification_date": "2026-05-20T14:54:37.8109366Z",
      "traits": []
    },
    {
      "locale": "enGB",
      "text": "\"Do not speak words you may come to regret.\"",
      "modification_date": "2026-05-22T12:17:38.8424682Z",
      "translated_from": "ruRU",
      "translation_date": "2026-05-29T15:16:36.0540463Z",
      "original_text": "\"Не произноси слов, о которых придется пожалеть\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-22T12:17:38.8424706Z",
          "locale_text": "\"Do not speak words you may come to regret.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-05-29T15:16:27.8472562Z",
          "locale_text": "\"Do not speak words you may come to regret.\""
        },
        {
          "trait": "FG_ed",
          "trait_date": "2026-05-29T15:16:27.8472566Z",
          "locale_text": "\"Do not speak words you may come to regret.\""
        },
        {
          "trait": "TK_rv",
          "trait_date": "2026-05-29T15:16:36.0540478Z",
          "locale_text": "\"Do not speak words you may come to regret.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«No diga nada de lo que pueda arrepentirse después».",
      "modification_date": "2026-06-01T08:46:49.1135623Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-01T08:46:49.1135625Z",
      "original_text": "\"Do not speak words you may come to regret.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-01T08:46:49.1135630Z",
          "locale_text": "«No diga nada de lo que pueda arrepentirse después»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“说话之前想清楚，免得后悔。”",
      "modification_date": "2026-06-01T08:49:02.0911607Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-01T08:49:02.0911608Z",
      "original_text": "\"Do not speak words you may come to regret.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-01T08:49:02.0911614Z",
          "locale_text": "“说话之前想清楚，免得后悔。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Gardez-vous de tenir des propos que vous pourriez regretter par la suite. »",
      "modification_date": "2026-06-02T08:53:11.9551601Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-02T08:53:11.9551604Z",
      "original_text": "\"Do not speak words you may come to regret.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-02T08:53:11.9551615Z",
          "locale_text": "« Gardez-vous de tenir des propos que vous pourriez regretter par la suite. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Sonradan pişman olacağın şeyler söyleme.\"",
      "modification_date": "2026-06-04T07:29:55.8197633Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-04T07:29:55.8197635Z",
      "original_text": "\"Do not speak words you may come to regret.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-04T07:29:55.8197642Z",
          "locale_text": "\"Sonradan pişman olacağın şeyler söyleme.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "後悔するような言葉は言わないで。",
      "modification_date": "2026-06-05T13:06:41.4709169Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-05T14:14:36.7097227Z",
      "original_text": "\"Do not speak words you may come to regret.\"",
      "traits": [
        {
          "trait": "AIGenerated",
          "trait_date": "2026-06-05T14:14:36.7097241Z",
          "locale_text": "後悔するような言葉は言わないで。"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Sagt nichts, was Ihr später bereuen könntet.\"",
