      ]
    },
    {
      "locale": "zhCN",
      "text": "“塞贝里安，别插嘴。我没允许你开口。”",
      "modification_date": "2026-06-01T08:49:01.9600573Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:40.0380035Z",
      "original_text": "\"Do not interfere, Seberian. I did not grant you permission to speak.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-22T06:56:40.0380052Z",
          "locale_text": "“塞贝里安，别插嘴。我没允许你开口。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Ne vous mêlez pas de ça, Seberian. Je ne vous ai pas donné la permission de parler. »",
      "modification_date": "2026-06-22T06:56:31.3114441Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:31.3114444Z",
      "original_text": "\"Do not interfere, Seberian. I did not grant you permission to speak.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-22T06:56:31.3114459Z",
          "locale_text": "« Ne vous mêlez pas de ça, Seberian. Je ne vous ai pas donné la permission de parler. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Sen karışma Seberian. Konuşmana izin vermedim.\"",
      "modification_date": "2026-06-10T07:24:47.0261954Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:34.6568990Z",
      "original_text": "\"Do not interfere, Seberian. I did not grant you permission to speak.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-22T06:56:34.6569006Z",
          "locale_text": "\"Sen karışma Seberian. Konuşmana izin vermedim.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「邪魔をするな、シベリア。君に話す許可は与えなかった。」",
      "modification_date": "2026-06-05T13:06:41.3272202Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-05T14:14:36.6881441Z",
      "original_text": "\"Do not interfere, Seberian. I did not grant you permission to speak.\"",
      "traits": [
        {
          "trait": "AIGenerated",
          "trait_date": "2026-06-05T14:14:36.6881449Z",
          "locale_text": "「邪魔をするな、シベリア。君に話す許可は与えなかった。」"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Mischt Euch nicht ein, Seberian. Ich habe Euch nicht erlaubt, zu sprechen.\"",
      "modification_date": "2026-06-22T06:56:27.5368473Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:27.5368477Z",
