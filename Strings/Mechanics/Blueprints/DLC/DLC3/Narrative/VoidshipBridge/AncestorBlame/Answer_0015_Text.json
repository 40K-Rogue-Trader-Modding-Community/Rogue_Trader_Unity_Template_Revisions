    {
      "locale": "esES",
      "text": "«No interfiera, Seberian. No le he dado permiso para hablar».",
      "modification_date": "2026-06-01T08:46:48.9218421Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:24.3660128Z",
