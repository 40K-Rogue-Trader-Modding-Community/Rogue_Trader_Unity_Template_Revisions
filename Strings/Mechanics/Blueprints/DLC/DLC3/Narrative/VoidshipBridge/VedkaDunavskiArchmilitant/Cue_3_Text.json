    {
      "locale": "trTR",
      "text": "\"Sizinle konuşmaktan büyük onur yoktur {mf|Lord|Leydi} Hazretleri.\"",
      "modification_date": "2026-05-14T10:16:01.2863508Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-14T10:16:01.2863509Z",
      "original_text": "\"Speaking with you is the greatest honour, Your {mf|Lordship|Ladyship}.\"",
      "traits": [
        {
