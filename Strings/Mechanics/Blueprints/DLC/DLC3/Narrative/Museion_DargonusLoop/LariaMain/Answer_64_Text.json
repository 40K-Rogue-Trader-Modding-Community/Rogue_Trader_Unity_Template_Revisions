    {
      "locale": "ruRU",
      "text": "\"Иных подтверждений моим подозрениям нет\".",
      "modification_date": "2026-03-10T22:15:36.8962678Z",
      "traits": [
        {
          "trait": "CheckMe",
          "trait_date": "2026-03-10T22:15:36.8962678Z",
          "locale_text": "\"Иных подтверждений моим подозрениям нет\".",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "enGB",
      "text": "\"There is no other evidence to confirm my suspicions.\"",
      "modification_date": "2026-04-20T08:47:41.4367383Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-20T08:47:41.4367384Z",
      "original_text": "\"Иных подтверждений моим подозрениям нет\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-20T08:47:41.4367389Z",
          "locale_text": "\"There is no other evidence to confirm my suspicions.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-20T08:47:41.4367391Z",
          "locale_text": "\"There is no other evidence to confirm my suspicions.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-04-20T08:47:41.4367392Z",
          "locale_text": "\"There is no other evidence to confirm my suspicions.\""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“暂时没有别的证据了。”",
      "modification_date": "2026-04-28T08:25:06.7003222Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-28T08:25:06.7003224Z",
      "original_text": "\"There is no other evidence to confirm my suspicions.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-28T08:25:06.7003230Z",
          "locale_text": "“暂时没有别的证据了。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Il n'y a pas d'autre preuve corroborant mes soupçons. »",
      "modification_date": "2026-04-28T08:31:22.9058561Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-28T08:31:22.9058563Z",
      "original_text": "\"There is no other evidence to confirm my suspicions.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-28T08:31:22.9058567Z",
          "locale_text": "« Il n'y a pas d'autre preuve corroborant mes soupçons. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Şüphelerimi doğrulayacak başka kanıtım yok.\"",
      "modification_date": "2026-04-29T08:06:40.7904513Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-29T08:06:40.7904515Z",
      "original_text": "\"There is no other evidence to confirm my suspicions.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-29T08:06:40.7904520Z",
          "locale_text": "\"Şüphelerimi doğrulayacak başka kanıtım yok.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«No hay más pruebas que confirmen mis sospechas».",
      "modification_date": "2026-05-06T08:29:37.4411567Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:29:37.4411568Z",
      "original_text": "\"There is no other evidence to confirm my suspicions.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:29:37.4411573Z",
          "locale_text": "«No hay más pruebas que confirmen mis sospechas»."
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Es gibt sonst keinen Beweis, der meinen Verdacht bestätigt.\"",
      "modification_date": "2026-05-18T09:00:30.6065591Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-18T09:00:30.6065592Z",
      "original_text": "\"There is no other evidence to confirm my suspicions.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-18T09:00:30.6065597Z",
          "locale_text": "\"Es gibt sonst keinen Beweis, der meinen Verdacht bestätigt.\""
        }
      ]
    },
    {
      "locale": "jaJP",
