    },
    {
      "locale": "esES",
      "text": "«Parece que he arruinado tus planes. ¿Ahora qué?».",
      "modification_date": "2026-03-10T07:48:20.6241941Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-10T07:48:20.6241943Z",
      "original_text": "\"I seem to have spoiled your plans. What now?\"",
