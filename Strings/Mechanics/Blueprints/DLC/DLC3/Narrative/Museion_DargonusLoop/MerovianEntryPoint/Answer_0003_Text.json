  "languages": [
    {
      "locale": "Sound",
      "text": "",
      "modification_date": "2025-11-07T08:12:33.2985237Z"
    },
    {
      "locale": "dev",
      "text": "Не знаю никакого пароля [неверный пароль, начинается бой]",
      "modification_date": "2025-11-27T13:28:42.2515121Z",
      "translation_comment": "Гварды становятся враждебны. Начинается бой",
      "traits": [
        {
          "trait": "CheckMe",
          "trait_date": "2025-11-07T08:15:22.3408994Z",
          "locale_text": "Не знаю никакого пароля [неверный пароль, начинается бой]",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "ruRU",
      "text": "\"И все же мой променад лежит ко дворцу\".",
      "modification_date": "2026-03-26T11:08:51.0282808Z",
      "translation_comment": "Гварды становятся враждебны. Начинается бой",
      "traits": [
        {
          "trait": "CheckMe",
          "trait_date": "2026-03-26T11:08:51.0282808Z",
          "locale_text": "\"И все же мой променад лежит ко дворцу\".",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "enGB",
      "text": "\"And, all the same, my promenade culminates in the palace.\"",
      "modification_date": "2026-04-20T08:47:43.1941432Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-20T08:47:43.1941433Z",
      "original_text": "\"И все же мой променад лежит ко дворцу\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-20T08:47:43.1941438Z",
          "locale_text": "\"And, all the same, my promenade culminates in the palace.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-20T08:47:43.1941440Z",
          "locale_text": "\"And, all the same, my promenade culminates in the palace.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-04-20T08:47:43.1941442Z",
          "locale_text": "\"And, all the same, my promenade culminates in the palace.\""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“不管怎么样，我这趟散步的终点，终究还是这座宫殿。”",
      "modification_date": "2026-04-28T08:25:07.6574293Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-28T08:25:07.6574295Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-28T08:25:07.6574301Z",
          "locale_text": "“不管怎么样，我这趟散步的终点，终究还是这座宫殿。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Malgré tout, ma promenade se termine au palais. »",
      "modification_date": "2026-04-28T08:31:23.9159013Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-28T08:31:23.9159015Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-28T08:31:23.9159020Z",
          "locale_text": "« Malgré tout, ma promenade se termine au palais. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Yine de yürüyüşüm sarayda son buluyor.\"",
      "modification_date": "2026-04-29T08:06:45.0740629Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-29T08:06:45.0740630Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-29T08:06:45.0740641Z",
          "locale_text": "\"Yine de yürüyüşüm sarayda son buluyor.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Y, sin embargo, mi camino termina en el palacio».",
      "modification_date": "2026-05-06T08:29:38.3981265Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:29:38.3981266Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:29:38.3981273Z",
          "locale_text": "«Y, sin embargo, mi camino termina en el palacio»."
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Und gleichwohl gipfelt mein Spaziergang im Palast.\"",
      "modification_date": "2026-05-18T09:00:31.6252660Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-18T09:00:31.6252662Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-18T09:00:31.6252673Z",
          "locale_text": "\"Und gleichwohl gipfelt mein Spaziergang im Palast.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「そして、同じように、私の散歩は宮殿で終わる」",
      "modification_date": "2026-06-05T13:06:34.1076356Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-05T14:14:35.5808568Z",
      "original_text": "\"And, all the same, my promenade culminates in the palace.\"",
      "traits": [
        {
          "trait": "AIGenerated",
          "trait_date": "2026-06-05T14:14:35.5808582Z",
          "locale_text": "「そして、同じように、私の散歩は宮殿で終わる」"
        }
      ]
    }
