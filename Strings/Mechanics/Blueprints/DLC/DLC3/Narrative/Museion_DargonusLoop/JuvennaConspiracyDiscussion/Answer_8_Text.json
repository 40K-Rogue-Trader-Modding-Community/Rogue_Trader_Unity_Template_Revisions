        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Sanırım Elana, diğerlerinin yanına dönmeliyiz.\"",
      "modification_date": "2026-04-06T09:48:31.4234928Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-06T09:48:31.4234930Z",
      "original_text": "\"I suppose, Elana, we ought to return to the others.\"",
