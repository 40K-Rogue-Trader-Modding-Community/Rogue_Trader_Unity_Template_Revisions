        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« J'ai entendu un chant en approchant du camp. »",
      "modification_date": "2026-05-18T09:02:42.3846994Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-18T09:02:42.3846996Z",
      "original_text": "\"As I approached the camp, I heard a song.\"",
