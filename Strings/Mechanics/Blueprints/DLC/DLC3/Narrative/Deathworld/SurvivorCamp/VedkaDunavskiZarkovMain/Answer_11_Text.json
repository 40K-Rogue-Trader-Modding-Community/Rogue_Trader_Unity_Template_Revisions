        {
          "trait": "Translated",
          "trait_date": "2026-05-18T09:02:42.3847003Z",
          "locale_text": "« J'ai entendu un chant en approchant du camp. »"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Cuando me acercaba al campamento, he oído una canción».",
