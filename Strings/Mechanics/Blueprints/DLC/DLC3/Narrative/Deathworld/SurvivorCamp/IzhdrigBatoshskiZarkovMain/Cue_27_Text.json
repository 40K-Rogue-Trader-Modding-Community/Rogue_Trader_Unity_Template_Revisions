    {
      "locale": "ruRU",
      "text": "\"Не имел такой цели, но что уж\".",
      "modification_date": "2026-03-26T08:58:52.1872213Z"
    },
    {
      "locale": "enGB",
      "text": "\"Wasn't my intention, but what's done is done.\"",
      "modification_date": "2026-04-14T06:12:21.7852111Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-14T06:12:21.7852116Z",
      "original_text": "\"Не имел такой цели, но что уж\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-14T06:12:21.7852137Z",
          "locale_text": "\"Wasn't my intention, but what's done is done.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-22T14:20:14.7629326Z",
          "locale_text": "\"Wasn't my intention, but what's done is done.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2025-11-11T07:48:30.2208395Z",
          "locale_text": "\"Good to know, Your {mf|Lordship|Ladyship}.\""
        },
        {
          "trait": "KO_tr",
          "trait_date": "2026-04-14T06:12:21.7852151Z",
          "locale_text": "\"Wasn't my intention, but what's done is done.\""
        },
        {
          "trait": "BMG_ed",
          "trait_date": "2026-04-22T14:20:14.7629330Z",
          "locale_text": "\"Wasn't my intention, but what's done is done.\""
        },
        {
          "trait": "TK_rv",
          "trait_date": "2026-06-06T22:43:06.6466297Z",
          "locale_text": "\"Wasn't my intention, but what's done is done.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「承知しました、{mf|閣下|閣下}」",
      "modification_date": "2025-11-12T09:59:31.6258753Z",
      "translated_from": "enGB",
      "translation_date": "2025-11-11T09:57:02.4865934Z",
      "original_text": "\"Good to know, Your {mf|Lordship|Ladyship}.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-11-11T09:57:02.4865938Z",
          "locale_text": "「承知しました、{mf|閣下|閣下}。」"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Telle n'était pas mon intention, mais ce qui est fait est fait. »",
      "modification_date": "2026-05-06T08:40:01.4784954Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:40:01.4784955Z",
      "original_text": "\"Wasn't my intention, but what's done is done.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:40:01.4784976Z",
          "locale_text": "« Telle n'était pas mon intention, mais ce qui est fait est fait. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Niyetim bu değildi ama oldu bir kere.\"",
      "modification_date": "2026-05-06T08:45:41.4186274Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:45:41.4186276Z",
      "original_text": "\"Wasn't my intention, but what's done is done.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:45:41.4186284Z",
          "locale_text": "\"Niyetim bu değildi ama oldu bir kere.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«No era lo que pretendía, pero lo hecho, hecho está».",
      "modification_date": "2026-05-06T08:44:19.8057624Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:44:19.8057626Z",
      "original_text": "\"Wasn't my intention, but what's done is done.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:44:19.8057634Z",
          "locale_text": "«No era lo que pretendía, pero lo hecho, hecho está»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“这不是我的本意，可事已至此。”",
      "modification_date": "2026-05-06T08:48:13.9214573Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:48:13.9214575Z",
      "original_text": "\"Wasn't my intention, but what's done is done.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:48:13.9214584Z",
          "locale_text": "“这不是我的本意，可事已至此。”"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Das war nicht meine Absicht, aber was geschehen ist, ist geschehen.\"",
      "modification_date": "2026-05-06T08:36:32.4405053Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:36:32.4405055Z",
      "original_text": "\"Wasn't my intention, but what's done is done.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:36:32.4405059Z",
          "locale_text": "\"Das war nicht meine Absicht, aber was geschehen ist, ist geschehen.\""
        }
      ]
    }
