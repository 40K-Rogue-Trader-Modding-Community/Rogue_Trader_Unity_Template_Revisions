        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Vous avez dit qu'il avait retiré quelque chose de son propre corps ? »",
      "modification_date": "2026-05-18T09:02:42.4274022Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-18T09:02:42.4274023Z",
      "original_text": "\"What did you say he removed from his own body?\"",
