    {
      "locale": "ruRU",
      "text": "\"На подходе к лагерю я слышал{mf||а} песню. Что это?\"",
      "modification_date": "2026-04-06T08:27:58.4608098+00:00"
    },
    {
      "locale": "enGB",
      "text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "modification_date": "2026-06-06T21:25:10.128314+00:00",
      "translated_from": "ruRU",
      "translation_date": "2026-04-14T06:12:21.5352542+00:00",
      "original_text": "\"На подходе к лагерю я слышал{mf||а} песню. Что это?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-14T06:12:21.5352549+00:00",
          "locale_text": "\"Colonel, I caught the sound of a melody as I approached the camp. What was it?\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-22T14:20:14.1762262+00:00",
          "locale_text": "\"Colonel, I caught the sound of a melody as I approached the camp. What was it?\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-02-04T08:09:54.7618151+00:00",
          "locale_text": "\"Colonel, I heard a song before we met.\""
        },
