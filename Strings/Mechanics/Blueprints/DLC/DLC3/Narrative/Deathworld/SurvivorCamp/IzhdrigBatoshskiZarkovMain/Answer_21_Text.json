    },
    {
      "locale": "frFR",
      "text": "« Colonel, j'ai entendu un chant en approchant du camp. De quoi s'agit-il ? »",
      "modification_date": "2026-06-29T07:09:54.973223+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-06-29T07:09:54.9732232+00:00",
      "original_text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-29T07:09:54.9732243+00:00",
          "locale_text": "« Colonel, j'ai entendu un chant en approchant du camp. De quoi s'agit-il ? »"
        },
        {
          "trait": "Translation_OutOfDate",
          "trait_date": "2026-06-23T15:51:30.1666185+00:00",
          "locale_text": "« Colonel, j'ai entendu le son d'une mélodie en approchant du camp. De quoi s'agit-il ? »"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Coronel, de camino al campamento pude oír una canción. ¿Qué era?».",
      "modification_date": "2026-06-29T07:11:36.528435+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-06-29T07:11:36.5284353+00:00",
      "original_text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-29T07:11:36.5284369+00:00",
          "locale_text": "«Coronel, de camino al campamento pude oír una canción. ¿Qué era?»."
        },
        {
          "trait": "Translation_OutOfDate",
          "trait_date": "2026-06-23T15:26:21.6342407+00:00",
          "locale_text": "«Coronel, de camino al campamento pude oír una melodía. ¿Qué era?»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“上校，我走近营地时听见有人在唱歌。那是什么歌？”",
      "modification_date": "2026-06-26T13:05:09.9023522+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-06-26T13:05:09.9023527+00:00",
      "original_text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-26T13:05:09.9023547+00:00",
          "locale_text": "“上校，我走近营地时听见有人在唱歌。那是什么歌？”"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Als ich mich dem Lager näherte, habe ich ein Lied gehört, Colonel. Was war das?\"",
      "modification_date": "2026-06-29T07:11:24.3548677+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-06-29T07:11:24.3548679+00:00",
      "original_text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-29T07:11:24.3548693+00:00",
          "locale_text": "\"Als ich mich dem Lager näherte, habe ich ein Lied gehört, Colonel. Was war das?\""
        },
        {
          "trait": "Translation_OutOfDate",
          "trait_date": "2026-06-23T14:05:33.650861+00:00",
          "locale_text": "\"Colonel, ich hörte eine Melodie, als ich mich dem Lager näherte. Was war das?\""
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Albay, kampa yaklaşırken bir şarkı duydum. Neydi o?\"",
      "modification_date": "2026-06-29T10:42:49.034227+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-06-29T10:42:49.0342272+00:00",
      "original_text": "\"Colonel, I heard a song as I approached the camp. What was it?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-29T10:42:49.0342281+00:00",
          "locale_text": "\"Albay, kampa yaklaşırken bir şarkı duydum. Neydi o?\""
        },
        {
          "trait": "Translation_OutOfDate",
          "trait_date": "2026-06-23T12:31:14.1051627+00:00",
          "locale_text": "\"Albay, kampa yaklaşırken bir melodi sesi işittim. Neydi o?\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「大佐、私達が出会う前に歌を聞いた」",
      "modification_date": "2026-02-09T12:56:16.7047121+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-02-09T12:45:39.9547709+00:00",
      "original_text": "\"Colonel, I heard a song before we met.\""
    }
