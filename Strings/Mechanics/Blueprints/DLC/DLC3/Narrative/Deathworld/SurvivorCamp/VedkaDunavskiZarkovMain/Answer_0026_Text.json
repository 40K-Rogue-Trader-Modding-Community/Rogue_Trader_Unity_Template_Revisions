    {
      "locale": "jaJP",
      "text": "「君たちの間では義肢が好まれているようだ」",
      "modification_date": "2025-11-12T12:37:34.9679012Z",
      "translated_from": "enGB",
      "translation_date": "2025-11-11T09:57:03.1686062Z",
