        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« J'ai cru remarquer que les prothèses avaient beaucoup de succès parmi vous. »",
      "modification_date": "2025-11-19T08:09:04.8273180Z",
      "translated_from": "enGB",
      "translation_date": "2025-11-19T08:09:04.8273181Z",
      "original_text": "\"I see that prosthetics are favoured among you.\"",
      "traits": [
