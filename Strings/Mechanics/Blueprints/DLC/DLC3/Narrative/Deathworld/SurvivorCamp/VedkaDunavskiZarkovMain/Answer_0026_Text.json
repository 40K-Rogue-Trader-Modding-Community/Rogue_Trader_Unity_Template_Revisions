          "trait_date": "2025-11-19T08:09:04.8273194Z",
          "locale_text": "« J'ai cru remarquer que les prothèses avaient beaucoup de succès parmi vous. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Protezlerin pek revaçta olduğunu görüyorum.\"",
      "modification_date": "2025-11-19T08:10:17.6510346Z",
      "translated_from": "enGB",
      "translation_date": "2025-11-19T08:10:17.6510347Z",
