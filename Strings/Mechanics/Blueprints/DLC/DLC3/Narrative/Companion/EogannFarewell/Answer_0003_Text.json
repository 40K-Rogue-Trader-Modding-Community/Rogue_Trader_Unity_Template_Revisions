        }
      ]
    },
    {
      "locale": "enGB",
      "text": "\"If we survive, what will you do after?\"",
      "modification_date": "2026-05-28T07:47:22.1306337Z",
      "translated_from": "ruRU",
      "translation_date": "2026-05-28T07:47:22.1306338Z",
      "original_text": "\"Если мы выживем, что ты будешь делать дальше?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-28T07:47:22.1306349Z",
          "locale_text": "\"If we survive, what will you do after?\""
        },
        {
