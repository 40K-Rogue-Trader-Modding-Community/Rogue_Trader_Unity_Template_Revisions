    },
    {
      "locale": "frFR",
      "text": "« Si quelque chose casse, je ne vous réparerai pas. »",
      "modification_date": "2026-05-07T08:24:42.7556132Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-07T08:24:42.7556134Z",
