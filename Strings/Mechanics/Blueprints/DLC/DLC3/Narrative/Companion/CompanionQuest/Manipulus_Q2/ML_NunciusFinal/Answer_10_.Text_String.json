    },
    {
      "locale": "frFR",
      "text": "« Vous avez pris la bonne décision. Il s'agit là d'un fait indéniable. »",
      "modification_date": "2026-04-15T08:02:36.3554019Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-15T08:02:36.3554021Z",
      "original_text": "\"You did the right thing. That is an incontrovertible fact.\"",
