    {
      "locale": "ruRU",
      "text": "\"Тогда не медли. Сделай что должно\".",
      "modification_date": "2026-03-12T19:51:06.2503638Z"
    },
    {
      "locale": "enGB",
      "text": "\"Then do not delay. Do what you must.\"",
      "modification_date": "2026-04-03T13:28:18.2266729Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-03T13:28:18.2266730Z",
      "original_text": "\"Тогда не медли. Сделай что должно\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-03T13:28:18.2266735Z",
          "locale_text": "\"Then do not delay. Do what you must.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-03T13:28:18.2266737Z",
          "locale_text": "\"Then do not delay. Do what you must.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-04-03T13:28:18.2266739Z",
          "locale_text": "\"Then do not delay. Do what you must.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Entonces no se demore. Haga lo que deba».",
      "modification_date": "2026-04-14T10:03:54.8273861Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:03:54.8273862Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-14T10:03:54.8273867Z",
          "locale_text": "«Entonces no se demore. Haga lo que deba»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“那就别磨蹭了。做你该做的事。”",
      "modification_date": "2026-04-14T10:07:12.4946600Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:07:12.4946601Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-14T10:07:12.4946618Z",
          "locale_text": "“那就别磨蹭了。做你该做的事。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Dans ce cas, ne perdez pas un instant. Faites ce que vous avez à faire. »",
      "modification_date": "2026-04-15T08:02:36.2440295Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-15T08:02:36.2440296Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-15T08:02:36.2440312Z",
          "locale_text": "« Dans ce cas, ne perdez pas un instant. Faites ce que vous avez à faire. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"O hâlde vakit kaybetme. Yapman gerekeni yap.\"",
      "modification_date": "2026-04-16T13:26:26.8409370Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-16T13:26:26.8409377Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-16T13:26:26.8409383Z",
          "locale_text": "\"O hâlde vakit kaybetme. Yapman gerekeni yap.\""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Dann zögert nicht. Tut, was Ihr tun müsst.\"",
      "modification_date": "2026-04-23T08:23:14.8243207Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-23T08:23:14.8243210Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-23T08:23:14.8243219Z",
          "locale_text": "\"Dann zögert nicht. Tut, was Ihr tun müsst.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「ならば、ためらうな。なすべきことをしろ」",
      "modification_date": "2026-06-05T10:19:08.7760142Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-05T14:14:48.3606254Z",
      "original_text": "\"Then do not delay. Do what you must.\"",
      "traits": [
