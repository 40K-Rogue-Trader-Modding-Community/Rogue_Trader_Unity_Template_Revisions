    {
      "locale": "jaJP",
      "text": "「これは私の決断です。」",
      "modification_date": "2026-03-13T12:33:34.8415249Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-13T12:33:34.8415251Z",
      "original_text": "\"This is my decision.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-03-13T12:33:34.8415265Z",
          "locale_text": "「これは私の決断です。」"
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“好了，伊奥贡，再试一次吧。”",
      "modification_date": "2026-06-01T08:49:04.8572224Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-01T08:49:04.8572227Z",
      "original_text": "\"All right, Eogunn, do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-01T08:49:04.8572234Z",
          "locale_text": "“好了，伊奥贡，再试一次吧。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Entendu, Eogunn, faites donc. »",
      "modification_date": "2026-06-02T08:53:15.7584073Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-02T08:53:15.7584076Z",
      "original_text": "\"All right, Eogunn, do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-02T08:53:15.7584089Z",
          "locale_text": "« Entendu, Eogunn, faites donc. »"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«De acuerdo, Eogunn, repita el proceso».",
      "modification_date": "2026-06-01T08:46:53.9598550Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-01T08:46:53.9598552Z",
      "original_text": "\"All right, Eogunn, do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-01T08:46:53.9598559Z",
          "locale_text": "«De acuerdo, Eogunn, repita el proceso»."
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Pekâlâ Eogunn, bir daha yap.\"",
      "modification_date": "2026-06-04T07:29:49.7491099Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-04T07:29:49.7491100Z",
      "original_text": "\"All right, Eogunn, do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-04T07:29:49.7491106Z",
          "locale_text": "\"Pekâlâ Eogunn, bir daha yap.\""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Also schön, Eogunn, macht es noch einmal.\"",
