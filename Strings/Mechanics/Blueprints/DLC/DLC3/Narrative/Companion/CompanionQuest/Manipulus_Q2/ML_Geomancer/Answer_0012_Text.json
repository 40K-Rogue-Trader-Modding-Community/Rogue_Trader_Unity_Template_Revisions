    {
      "locale": "ruRU",
      "text": "\"Эоганн, делай с ним, что пожелаешь\".",
      "modification_date": "2026-03-26T10:26:32.9705841Z"
    },
    {
      "locale": "enGB",
      "text": "\"Eogunn, do with him as you wish.\"",
      "modification_date": "2026-02-27T11:18:34.9540025Z",
      "translated_from": "ruRU",
      "translation_date": "2026-01-20T07:38:29.7691081Z",
      "original_text": "\"Эоганн, делай с ним, что пожелаешь\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-20T07:38:29.7691086Z",
          "locale_text": "\"Eo-gann, do with him as you wish.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-01-20T07:38:29.7691089Z",
          "locale_text": "\"Eo-gann, do with him as you wish.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-01-20T07:38:29.7691091Z",
          "locale_text": "\"Eo-gann, do with him as you wish.\""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“伊奥贡，他交给你处置了。”",
      "modification_date": "2026-06-08T10:36:58.5804129Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-26T07:04:23.5449994Z",
      "original_text": "\"Eogunn, do with him as you wish.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-26T07:04:23.5450000Z",
          "locale_text": "“埃欧-甘，他交给你处置了。”"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Usted decide qué hacemos con él, Eogunn».",
      "modification_date": "2026-02-27T11:33:54.6558317Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-26T07:07:03.9164431Z",
      "original_text": "\"Eogunn, do with him as you wish.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-26T07:07:03.9164435Z",
          "locale_text": "«Usted decide qué hacemos con él, Eo-gann»."
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Eogunn, faites ce que vous voudrez de lui. »",
      "modification_date": "2026-02-27T11:26:46.0620186Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-26T07:08:34.7342772Z",
      "original_text": "\"Eogunn, do with him as you wish.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-26T07:08:34.7342777Z",
          "locale_text": "« Eo-gann, faites ce que vous voudrez de lui. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Eogunn, ona ne istersen yap.\"",
      "modification_date": "2026-02-27T12:51:08.8508956Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-26T13:07:09.3009179Z",
      "original_text": "\"Eogunn, do with him as you wish.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-26T13:07:09.3009194Z",
          "locale_text": "\"Eo-gann, ona ne istersen yap.\""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Eogunn, macht mit ihm, was Ihr wollt.\"",
      "modification_date": "2026-02-27T11:21:55.6608970Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-27T08:03:38.9983258Z",
      "original_text": "\"Eogunn, do with him as you wish.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-01-27T08:03:38.9983272Z",
          "locale_text": "\"Eo-gann, macht mit ihm, was Ihr wollt.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「エオガン、彼をどうしたいが自由だ」",
      "modification_date": "2026-01-27T09:08:11.1474722Z",
      "translated_from": "enGB",
      "translation_date": "2026-01-27T09:08:11.1474724Z",
