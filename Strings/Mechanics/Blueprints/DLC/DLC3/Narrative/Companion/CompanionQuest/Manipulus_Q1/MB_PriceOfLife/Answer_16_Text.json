      "translated_from": "enGB",
      "translation_date": "2026-06-10T14:14:22.6654093Z",
      "original_text": "\"Nuncius, shed some light on these experiments, would you?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-10T14:14:22.6654112Z",
          "locale_text": "“努恩修斯，可否说明一下这些实验？”"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Nuncius, explíqueme estos experimentos, si tiene la bondad».",
