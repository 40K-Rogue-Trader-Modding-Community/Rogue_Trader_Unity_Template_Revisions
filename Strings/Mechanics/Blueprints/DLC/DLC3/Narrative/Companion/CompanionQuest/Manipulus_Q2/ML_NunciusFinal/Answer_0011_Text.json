    },
    {
      "locale": "esES",
      "text": "«No le queda mucho tiempo. Diga lo que tenga que decir».",
      "modification_date": "2026-04-14T10:03:54.8497522Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:03:54.8497523Z",
      "original_text": "\"You don't have much time. Say what you have to say.\"",
