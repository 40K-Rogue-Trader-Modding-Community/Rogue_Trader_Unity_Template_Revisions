        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“你的时间不多了，有什么想说的就说吧。”",
      "modification_date": "2026-04-14T10:07:12.5098849Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:07:12.5098851Z",
      "original_text": "\"You don't have much time. Say what you have to say.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-14T10:07:12.5098861Z",
          "locale_text": "“你的时间不多了，有什么想说的就说吧。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Il vous reste peu de temps. Dites ce que vous avez à dire. »",
      "modification_date": "2026-04-15T08:02:36.2606572Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-15T08:02:36.2606573Z",
      "original_text": "\"You don't have much time. Say what you have to say.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-15T08:02:36.2606590Z",
          "locale_text": "« Il vous reste peu de temps. Dites ce que vous avez à dire. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Fazla zamanın yok. Ne söylemen gerekiyorsa söyle.\"",
      "modification_date": "2026-04-16T13:26:27.3128185Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-16T13:26:27.3128187Z",
      "original_text": "\"You don't have much time. Say what you have to say.\"",
