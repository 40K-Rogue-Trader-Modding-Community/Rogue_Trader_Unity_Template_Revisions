        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Concentrez-vous sur le plus important. Rappelez-vous qui vous êtes. »",
      "modification_date": "2026-03-19T14:24:00.874453Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-19T14:24:00.8744531Z",
