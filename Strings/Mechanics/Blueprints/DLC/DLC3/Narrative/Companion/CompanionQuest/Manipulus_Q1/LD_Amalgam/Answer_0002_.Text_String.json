    {
      "locale": "jaJP",
      "text": "「最も重要なことに集中し、自分が誰であるかを忘れないでくれ」",
      "modification_date": "2026-03-13T14:22:18.987162Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-13T12:33:34.833611Z",
