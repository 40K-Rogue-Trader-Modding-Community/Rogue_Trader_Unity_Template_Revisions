      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-03-13T15:33:34.833612+03:00",
          "locale_text": "「最も重要なことに集中し、自分が誰であるかを忘れないでください。」"
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“专心于最重要的事。记清楚你是谁。”",
      "modification_date": "2026-03-19T14:22:12.0676145Z",
      "translated_from": "enGB",
      "translation_date": "2026-03-19T14:22:12.0676146Z",
