        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“那就告诉我，阿姆桑克特上究竟出了什么事。”",
      "modification_date": "2026-04-02T08:03:34.6479340Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-02T08:03:34.6479342Z",
      "original_text": "\"Then tell me what really happened on Amsanct.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-02T08:03:34.6479348Z",
          "locale_text": "“那就告诉我，阿姆桑克特上究竟出了什么事。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Très bien, dites-moi ce qui s'est passé sur Amsanct. »",
      "modification_date": "2026-04-03T08:25:54.2144889Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-03T08:25:54.2144890Z",
      "original_text": "\"Then tell me what really happened on Amsanct.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-03T08:25:54.2144906Z",
          "locale_text": "« Très bien, dites-moi ce qui s'est passé sur Amsanct. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"O zaman bana Amsanct'ta gerçekten ne olduğunu anlat.\"",
