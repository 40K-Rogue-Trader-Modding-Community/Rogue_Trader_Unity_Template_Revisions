      "translated_from": "enGB",
      "translation_date": "2026-04-28T14:25:44.6817101Z",
      "original_text": "\"Eogunn, why did you conduct this experiment outside the laboratory?\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-28T14:25:44.6817116Z",
          "locale_text": "“伊奥贡，你为什么要在实验室外进行这项实验？”"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Eogunn, ¿por qué ha llevado a cabo este experimento fuera del laboratorio?».",
