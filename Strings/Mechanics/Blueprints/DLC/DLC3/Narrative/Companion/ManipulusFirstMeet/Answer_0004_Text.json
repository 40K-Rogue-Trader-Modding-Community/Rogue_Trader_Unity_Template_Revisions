    {
      "locale": "ruRU",
      "text": "\"Зачем ты напал на своего прислужника? Не делай так больше\".",
      "modification_date": "2026-01-30T15:34:29.247355+03:00"
    },
    {
      "locale": "enGB",
      "text": "\"Why did you attack that menial? Do not do it again.\"",
      "modification_date": "2026-02-09T07:20:01.7063305Z",
      "translated_from": "ruRU",
      "translation_date": "2026-02-09T07:20:01.7063306Z",
      "original_text": "\"Зачем ты напал на своего прислужника? Не делай так больше\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-02-09T10:20:01.7063318+03:00",
          "locale_text": "\"Why did you attack that menial? Do not do it again.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-02-09T10:20:01.7063328+03:00",
          "locale_text": "\"Why did you attack that menial? Do not do it again.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-02-09T10:20:01.7063329+03:00",
          "locale_text": "\"Why did you attack that menial? Do not do it again.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「なぜ、その下僕を襲ったのか。二度と繰り返さないでくれ」",
      "modification_date": "2026-02-09T09:43:58.3622953Z",
      "translated_from": "enGB",
      "translation_date": "2026-02-09T09:05:14.1388078Z",
      "original_text": "\"Why did you attack that menial? Do not do it again.\""
    },
    {
      "locale": "deDE",
      "text": "\"Warum habt Ihr diesen Lakaien angegriffen? Macht das nicht noch einmal.\"",
      "modification_date": "2026-02-12T08:09:40.4330792Z",
      "translated_from": "enGB",
      "translation_date": "2026-02-12T08:09:40.4330794Z",
      "original_text": "\"Why did you attack that menial? Do not do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-02-12T11:09:40.4330807+03:00",
          "locale_text": "\"Warum habt Ihr diesen Lakaien angegriffen? Macht das nicht noch einmal.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«¿Por qué ha atacado al servicio? No vuelva a hacerlo».",
      "modification_date": "2026-02-12T08:10:22.4028218Z",
      "translated_from": "enGB",
      "translation_date": "2026-02-12T08:10:22.402822Z",
      "original_text": "\"Why did you attack that menial? Do not do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-02-12T11:10:22.4028225+03:00",
          "locale_text": "«¿Por qué ha atacado al servicio? No vuelva a hacerlo»."
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"O işçiye neden saldırdın? Bunu bir daha yapma.\"",
      "modification_date": "2026-02-12T15:26:55.9840747Z",
      "translated_from": "enGB",
      "translation_date": "2026-02-12T15:26:55.9840749Z",
      "original_text": "\"Why did you attack that menial? Do not do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-02-12T18:26:55.9840763+03:00",
          "locale_text": "\"O işçiye neden saldırdın? Bunu bir daha yapma.\""
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Pourquoi avoir attaqué ce subalterne ? Ne recommencez pas. »",
      "modification_date": "2026-02-12T15:26:56.4119782Z",
      "translated_from": "enGB",
      "translation_date": "2026-02-12T15:26:56.4119783Z",
      "original_text": "\"Why did you attack that menial? Do not do it again.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-02-12T18:26:56.411979+03:00",
          "locale_text": "« Pourquoi avoir attaqué ce subalterne ? Ne recommencez pas. »"
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“你为何攻击那个仆役？以后不要这么做了。”",
