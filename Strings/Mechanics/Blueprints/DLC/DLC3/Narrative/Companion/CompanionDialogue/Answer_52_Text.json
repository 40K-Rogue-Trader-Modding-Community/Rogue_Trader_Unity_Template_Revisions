        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Non. J'ai raison, un point c'est tout. »",
      "modification_date": "2026-04-15T08:02:29.8037584Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-15T08:02:29.8037585Z",
      "original_text": "\"I would not. I'm right, and that's all there is to it.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-15T08:02:29.8037592Z",
          "locale_text": "« Non. J'ai raison, un point c'est tout. »"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Würde ich nicht. Ich habe recht, das ist alles.\"",
      "modification_date": "2026-04-23T08:23:05.9627387Z",
