    {
      "locale": "zhCN",
      "text": "“我不同意。一个人生命的意义，由他自己决定。”",
      "modification_date": "2026-04-14T10:07:10.2205489Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:07:10.2205490Z",
