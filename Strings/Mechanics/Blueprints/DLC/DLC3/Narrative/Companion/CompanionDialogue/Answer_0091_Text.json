      ]
    },
    {
      "locale": "esES",
      "text": "«Desde luego. Y a pesar de ello, gané la discusión».",
      "modification_date": "2026-05-21T07:50:45.4860080Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T07:50:45.4860081Z",
      "original_text": "\"Absolutely. Nevertheless, I still won the debate.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T07:50:45.4860087Z",
          "locale_text": "«Desde luego. Y a pesar de ello, gané la discusión»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“确实。但不管怎么说，这场辩论还是我赢了。”",
      "modification_date": "2026-05-21T07:45:51.3017841Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T07:45:51.3017843Z",
      "original_text": "\"Absolutely. Nevertheless, I still won the debate.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T07:45:51.3017866Z",
          "locale_text": "“确实。但不管怎么说，这场辩论还是我赢了。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Absolument. Mais j'ai quand même remporté ce débat. »",
      "modification_date": "2026-05-21T14:32:20.2946317Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T14:32:20.2946320Z",
      "original_text": "\"Absolutely. Nevertheless, I still won the debate.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T14:32:20.2946337Z",
          "locale_text": "« Absolument. Mais j'ai quand même remporté ce débat. »"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Absolut. Ich werde trotzdem nicht diskutieren.\"",
      "modification_date": "2026-05-22T08:31:03.3278872Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-22T08:31:03.3278875Z",
      "original_text": "\"Absolutely. Nevertheless, I still won the debate.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-22T08:31:03.3278901Z",
          "locale_text": "\"Absolut. Ich werde trotzdem nicht diskutieren.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「その通り。それでも、議論に勝ったのは私だ。」",
      "modification_date": "2026-06-10T08:08:49.4665603Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-10T08:08:49.4665605Z",
