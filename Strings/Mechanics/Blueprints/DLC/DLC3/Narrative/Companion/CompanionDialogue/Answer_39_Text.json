    },
    {
      "locale": "frFR",
      "text": "« Je ne pense pas à la mort, la vie m'occupe déjà suffisamment. »",
      "modification_date": "2026-04-15T08:02:29.5052440Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-15T08:02:29.5052442Z",
      "original_text": "\"I do not care about dying. I am too busy living.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-15T08:02:29.5052451Z",
          "locale_text": "« Je ne pense pas à la mort, la vie m'occupe déjà suffisamment. »"
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"Der Tod interessiert mich nicht. Ich bin damit beschäftigt, zu leben.\"",
      "modification_date": "2026-04-23T08:23:05.5662436Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-23T08:23:05.5662437Z",
      "original_text": "\"I do not care about dying. I am too busy living.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-23T08:23:05.5662446Z",
          "locale_text": "\"Der Tod interessiert mich nicht. Ich bin damit beschäftigt, zu leben.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「死ぬことなど気にしない。生きることで精一杯なんだ。」",
      "modification_date": "2026-06-09T16:05:44.0878629Z",
