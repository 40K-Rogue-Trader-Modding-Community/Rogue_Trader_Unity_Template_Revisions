    },
    {
      "locale": "zhCN",
      "text": "“我不在乎死亡。我忙着活呢。”",
      "modification_date": "2026-04-14T10:07:10.5229203Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-14T10:07:10.5229204Z",
      "original_text": "\"I do not care about dying. I am too busy living.\"",
