    {
      "locale": "jaJP",
      "text": "「もう十分聞いた。行け。」",
      "modification_date": "2025-12-15T13:14:33.8548086+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-15T13:14:33.8548088+03:00",
      "original_text": "\"I suppose I have heard enough. Go.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-15T13:14:33.8548096+03:00",
          "locale_text": "「もう十分聞いた。行け。」"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Sanırım bu kadar yeter. Gidelim.\"",
      "modification_date": "2025-12-17T13:03:04.6616826+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-17T13:03:04.6616829+03:00",
      "original_text": "\"I suppose I have heard enough. Go.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-17T13:03:04.6616835+03:00",
          "locale_text": "\"Sanırım bu kadar yeter. Gidelim.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«Supongo que ya he oído suficiente. Márchese».",
      "modification_date": "2025-12-18T11:06:36.0946693+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-18T11:06:36.0946694+03:00",
      "original_text": "\"I suppose I have heard enough. Go.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-18T11:06:36.0946699+03:00",
          "locale_text": "«Supongo que ya he oído suficiente. Márchese»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“我听得够多了。退下吧。”",
      "modification_date": "2025-12-18T11:09:28.0474161+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-18T11:09:28.0474162+03:00",
      "original_text": "\"I suppose I have heard enough. Go.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-18T11:09:28.0474167+03:00",
          "locale_text": "“我听得够多了。退下吧。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« J'en ai assez entendu, ce me semble. Vous pouvez disposer. »",
      "modification_date": "2025-12-18T11:11:27.0568561+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-18T11:11:27.0568563+03:00",
      "original_text": "\"I suppose I have heard enough. Go.\"",
