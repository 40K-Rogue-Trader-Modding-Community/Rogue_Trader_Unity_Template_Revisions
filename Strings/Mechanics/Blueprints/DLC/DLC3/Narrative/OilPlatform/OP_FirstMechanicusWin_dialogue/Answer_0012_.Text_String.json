    {
      "locale": "ruRU",
      "text": "\"Я сказал{mf||а}: анкер-ядро. Сейчас же\".",
      "modification_date": "2025-11-30T23:48:12.9107714+03:00",
      "traits": [
        {
          "trait": "CheckMe",
          "trait_date": "2025-11-19T15:29:15.6245384+03:00",
          "locale_text": "\"Последствия очевидны. Если я не получу желаемое, на Алтарь-Темплум придет отчет о том, что станция охвачена техноересью. После этого она будет уничтожена в любом случае. Таковы факты\".",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "enGB",
      "text": "\"The anchor-core, I said. Now.\"",
      "modification_date": "2025-12-11T11:36:18.6265692+03:00",
      "translated_from": "ruRU",
      "translation_date": "2025-12-11T11:36:18.6265694+03:00",
      "original_text": "\"Я сказал{mf||а}: анкер-ядро. Сейчас же\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-11T11:36:18.6265698+03:00",
          "locale_text": "\"The anchor-core, I said. Now.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2025-12-11T11:36:18.6265701+03:00",
          "locale_text": "\"The anchor-core, I said. Now.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2025-12-11T11:36:18.6265702+03:00",
          "locale_text": "\"The anchor-core, I said. Now.\""
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「アンカー・コア、と言った。今だ。」",
      "modification_date": "2025-12-15T13:14:34.0685536+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-15T13:14:34.0685537+03:00",
      "original_text": "\"The anchor-core, I said. Now.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-15T13:14:34.0685543+03:00",
          "locale_text": "「アンカー・コア、と言った。今だ。」"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Çapa çekirdeği dedim. Şimdi.\"",
      "modification_date": "2025-12-17T13:03:04.3889764+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-17T13:03:04.388978+03:00",
      "original_text": "\"The anchor-core, I said. Now.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-17T13:03:04.38898+03:00",
          "locale_text": "\"Çapa çekirdeği dedim. Şimdi.\""
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«El núcleo de anclaje. Lo quiero aquí ya».",
      "modification_date": "2025-12-18T11:06:35.8710361+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-18T11:06:35.8710362+03:00",
      "original_text": "\"The anchor-core, I said. Now.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-18T11:06:35.871037+03:00",
          "locale_text": "«El núcleo de anclaje. Lo quiero aquí ya»."
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“我说了，我要锚核。现在，立刻。”",
      "modification_date": "2025-12-18T11:09:27.829363+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-18T11:09:27.8293631+03:00",
      "original_text": "\"The anchor-core, I said. Now.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2025-12-18T11:09:27.8293636+03:00",
          "locale_text": "“我说了，我要锚核。现在，立刻。”"
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Le noyau ancestral, j'ai dit. Et plus vite que ça. »",
