    },
    {
      "locale": "trTR",
      "text": "\"Git mon-keigh. {n}{g|Encyclopedia:AeldariGlossary}Aeldari'nin{/g} sesi, oldukça soğukkanlı çıkıyor.{/n}",
      "modification_date": "2026-05-06T08:04:44.2203033Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-06T08:04:44.2203035Z",
      "original_text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-06T08:04:44.2203040Z",
          "locale_text": "\"Git mon-keigh. {n}{g|Encyclopedia:AeldariGlossary}Aeldari'nin{/g} sesi, oldukça soğukkanlı çıkıyor.{/n}"
