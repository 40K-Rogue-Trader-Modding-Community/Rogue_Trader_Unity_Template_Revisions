    {
      "locale": "ruRU",
      "text": "\"Уходи, мон-кай\". {n}В голосе {g|Encyclopedia:AeldariGlossary}эльдара{/g} вы не слышите ни намека на иронию.{/n}",
      "modification_date": "2026-03-27T10:14:58.2192695Z",
      "traits": [
        {
          "trait": "CheckMe",
          "trait_date": "2026-03-27T10:14:58.2192695Z",
          "locale_text": "\"Уходи, мон-кай\". {n}В голосе {g|Encyclopedia:AeldariGlossary}эльдара{/g} вы не слышите ни намека на иронию.{/n}",
          "speaker": "",
          "speaker_gender": ""
        }
      ]
    },
    {
      "locale": "enGB",
      "text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}",
      "modification_date": "2026-04-09T16:29:18.7408460Z",
      "translated_from": "ruRU",
      "translation_date": "2026-04-23T12:26:48.2387728Z",
      "original_text": "\"Уходи, мон-кай\". {n}В голосе {g|Encyclopedia:AeldariGlossary}эльдара{/g} вы не слышите ни намека на иронию.{/n}",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-09T16:29:18.7408481Z",
          "locale_text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}"
        },
        {
          "trait": "Edited",
          "trait_date": "2026-04-23T12:26:48.2387744Z",
          "locale_text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}"
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2025-12-19T08:44:20.1992423Z",
          "locale_text": "\"Go away, mon-keigh.\" {n}You hear no hint of irony in the Aeldari's voice.{/n}"
        },
        {
          "trait": "TK_tr",
          "trait_date": "2026-04-09T16:29:18.7408490Z",
          "locale_text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}"
        },
        {
          "trait": "AD_ed",
          "trait_date": "2026-04-23T12:26:48.2387749Z",
          "locale_text": "\"Leave, mon-keigh.\" {n}The {g|Encyclopedia:AeldariGlossary}Aeldari{/g}'s voice is matter-of-fact.{/n}"
        }
      ]
    },
    {
      "locale": "jaJP",
      "text": "「消えろ、モンキー」{n}アエルダリの声には皮肉が全く感じられない。{/n}",
      "modification_date": "2025-12-22T08:13:21.5523367Z",
