    {
      "locale": "ruRU",
      "text": "\"В таком случае, время не ждет\".",
      "modification_date": "2026-04-29T18:23:00.3305270Z"
    },
    {
      "locale": "enGB",
      "text": "\"In that case, time is of the essence.\"",
      "modification_date": "2026-05-08T14:08:00.5642711Z",
      "translated_from": "ruRU",
      "translation_date": "2026-05-08T14:08:00.5642712Z",
      "original_text": "\"В таком случае, время не ждет\".",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-08T14:08:00.5642734Z",
          "locale_text": "\"In that case, time is of the essence.\""
        },
        {
          "trait": "Edited",
          "trait_date": "2026-05-08T14:08:00.5642736Z",
          "locale_text": "\"In that case, time is of the essence.\""
        },
        {
          "trait": "AD_tr_ed",
          "trait_date": "2026-05-08T14:08:00.5642738Z",
          "locale_text": "\"In that case, time is of the essence.\""
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“既然如此，那就必须争分夺秒。”",
      "modification_date": "2026-05-21T07:45:57.4662022Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T07:45:57.4662023Z",
      "original_text": "\"In that case, time is of the essence.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T07:45:57.4662028Z",
          "locale_text": "“既然如此，那就必须争分夺秒。”"
        }
      ]
    },
    {
      "locale": "esES",
      "text": "«En ese caso, el tiempo es vital».",
      "modification_date": "2026-05-21T07:50:47.7571008Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T07:50:47.7571009Z",
      "original_text": "\"In that case, time is of the essence.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T07:50:47.7571020Z",
          "locale_text": "«En ese caso, el tiempo es vital»."
        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« En ce cas, le temps nous est compté. »",
      "modification_date": "2026-05-21T10:11:02.8370819Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-21T10:11:02.8370820Z",
      "original_text": "\"In that case, time is of the essence.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-21T10:11:02.8370837Z",
          "locale_text": "« En ce cas, le temps nous est compté. »"
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Vakit kaybetmemek çok önemli.\"",
      "modification_date": "2026-05-22T12:23:30.0966274Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-22T12:23:30.0966276Z",
      "original_text": "\"In that case, time is of the essence.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-22T12:23:30.0966290Z",
          "locale_text": "\"Vakit kaybetmemek çok önemli.\""
        }
      ]
    },
    {
      "locale": "deDE",
      "text": "\"In diesem Fall ist Eile geboten.\"",
      "modification_date": "2026-05-26T10:09:08.2185080Z",
      "translated_from": "enGB",
      "translation_date": "2026-05-26T10:09:08.2185082Z",
      "original_text": "\"In that case, time is of the essence.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-05-26T10:09:08.2185088Z",
          "locale_text": "\"In diesem Fall ist Eile geboten.\""
        }
      ]
    },
    {
