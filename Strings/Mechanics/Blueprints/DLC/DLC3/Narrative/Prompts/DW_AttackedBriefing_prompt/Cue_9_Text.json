    {
      "locale": "frFR",
      "text": "« On nous envoie un signal-vox, mais je ne parviens pas à en déterminer la source. »",
      "modification_date": "2026-06-22T06:56:31.2228128Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:31.2228131Z",
      "original_text": "\"We have an incoming vox-signal, but I cannot identify the source.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-06-22T06:56:31.2228146Z",
          "locale_text": "« On nous envoie un signal-vox, mais je ne parviens pas à en déterminer la source. »"
        }
      ]
    },
    {
      "locale": "zhCN",
      "text": "“有音阵信号接入，但我无法识别来源。”",
      "modification_date": "2026-05-13T10:52:37.5467580Z",
      "translated_from": "enGB",
      "translation_date": "2026-06-22T06:56:39.8682483Z",
      "original_text": "\"We have an incoming vox-signal, but I cannot identify the source.\"",
      "traits": [
