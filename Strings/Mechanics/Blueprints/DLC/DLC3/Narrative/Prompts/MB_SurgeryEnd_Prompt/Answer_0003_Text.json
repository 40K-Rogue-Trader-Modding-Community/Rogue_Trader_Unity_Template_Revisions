    },
    {
      "locale": "trTR",
      "text": "\"Tek kelime daha etme. Derhâl oraya gidiyorum.\"",
      "modification_date": "2025-12-10T15:05:35.0787884+03:00",
      "translated_from": "enGB",
      "translation_date": "2025-12-10T15:05:35.0787885+03:00",
      "original_text": "\"Not another word. I shall go there immediately.\"",
