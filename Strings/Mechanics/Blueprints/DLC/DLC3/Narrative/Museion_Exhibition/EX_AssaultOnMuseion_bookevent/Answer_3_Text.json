        }
      ]
    },
    {
      "locale": "frFR",
      "text": "« Nous ne pouvons perdre de temps à nous battre. Empruntons le couloir de droite. »",
      "modification_date": "2026-06-03T15:10:49.6105841Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-27T09:11:53.7560801Z",
      "original_text": "\"We cannot waste our time fighting. Let us take the corridor on the right.\"",
      "traits": [
        {
          "trait": "Translated",
          "trait_date": "2026-04-27T09:11:53.7560811Z",
          "locale_text": "Nous ne pouvons perdre de temps à nous battre. Empruntons le couloir de droite."
        }
      ]
    },
    {
      "locale": "trTR",
      "text": "\"Zamanımızı savaşarak harcayamayız. Sağdaki koridordan gidelim.\"",
