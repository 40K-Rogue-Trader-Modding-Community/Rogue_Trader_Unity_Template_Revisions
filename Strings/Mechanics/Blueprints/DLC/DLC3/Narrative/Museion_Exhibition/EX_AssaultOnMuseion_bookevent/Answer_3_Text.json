        }
      ]
    },
    {
      "locale": "esES",
      "text": "«No podemos perder tiempo luchando. Vayamos por el pasillo de la derecha».",
      "modification_date": "2026-04-27T09:11:51.5632104Z",
      "translated_from": "enGB",
      "translation_date": "2026-04-27T09:11:51.5632105Z",
      "original_text": "\"We cannot waste our time fighting. Let us take the corridor on the right.\"",
      "traits": [
