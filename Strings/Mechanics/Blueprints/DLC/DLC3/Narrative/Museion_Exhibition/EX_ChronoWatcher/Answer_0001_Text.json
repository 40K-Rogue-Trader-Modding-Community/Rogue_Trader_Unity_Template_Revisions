    },
    {
      "locale": "zhCN",
      "text": "“让我过去，就不会有人受伤。”",
      "modification_date": "2026-01-08T09:34:26.7398356+00:00",
      "translated_from": "enGB",
      "translation_date": "2026-01-08T09:34:26.7398358+00:00",
      "original_text": "\"Let me pass, and no one will be harmed.\"",
